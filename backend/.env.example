# 应用
NODE_ENV=development
PORT=3001

# MySQL 数据库
DATABASE_URL=mysql://root:YOUR_PASSWORD@localhost:3306/github_projects_hub

# JWT（生产环境务必替换为高强度随机字符串）
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-to-another-random-string
JWT_REFRESH_EXPIRES_IN=30d

# GitHub OAuth（需要在 GitHub Developer Settings 创建 OAuth App）
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback

# GitHub API Token Pool（逗号分隔，用于突破速率限制）
GITHUB_TOKENS=ghp_xxxxxxxxxxxxxxxxxxxx

# 前端
FRONTEND_URL=http://localhost:3000
